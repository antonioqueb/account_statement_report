<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_account_statement" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.account.statement</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_print_account_statement"
                        type="object"
                        string="Estado de Cuenta"
                        class="btn-secondary"
                        icon="fa-file-text-o"
                        groups="sales_team.group_sale_salesman"
                        invisible="state in ('draft', 'sent', 'cancel')"/>
            </xpath>

            <!-- Indicador de saldo a favor del cliente, debajo del total -->
            <xpath expr="//field[@name='tax_totals']" position="after">
                <field name="x_company_currency_id" invisible="1"/>
                <field name="x_has_customer_credit" invisible="1"/>
                <div class="oe_subtotal_footer_separator"
                     invisible="not x_has_customer_credit"
                     style="margin-top: 8px;">
                    <div class="alert alert-success text-end mb-0 py-2 px-3"
                         role="alert"
                         style="border-left: 4px solid #28a745;">
                        <span class="text-uppercase fw-bold" style="font-size: 11px;">Saldo a Favor del Cliente</span>
                        <br/>
                        <span class="fw-bolder" style="font-size: 18px; color: #28a745;">
                            <field name="x_customer_credit_balance" widget="monetary"
                                   options="{'currency_field': 'x_company_currency_id'}"
                                   nolabel="1"/>
                        </span>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
