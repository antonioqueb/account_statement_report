<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_account_statement" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.account.statement</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_print_account_statement"
                        type="object"
                        string="Estado de Cuenta"
                        class="btn-secondary"
                        icon="fa-file-text-o"
                        groups="sales_team.group_sale_salesman"
                        invisible="state in ('draft', 'sent', 'cancel')"/>
            </xpath>
        </field>
    </record>
</odoo>
